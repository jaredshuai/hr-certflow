APP_NAME=HR CertFlow
APP_ENV=local
APP_TIMEZONE=Asia/Shanghai
AUTO_CREATE_TABLES=true
API_CORS_ORIGINS=http://localhost:8001

DATABASE_URL=postgresql+psycopg://<postgres-user>:<postgres-password>@<postgres-host>:5432/<postgres-db>
REDIS_URL=redis://<redis-user>:<redis-password>@<redis-host>:6379/0
CELERY_BROKER_URL=
CELERY_RESULT_BACKEND=
CELERY_NAMESPACE=hr-certflow-local
CELERY_QUEUE=hr-certflow-local
CELERY_ROUTING_KEY=hr-certflow-local
CELERY_REDIS_HASH_TAG=hr-certflow-local
CELERY_REDIS_PREFIX=hr-certflow-local:
POSTGRES_HOST_PORT=15432
REDIS_HOST_PORT=16379
API_HOST_PORT=8000
FRONTEND_HOST_PORT=8001

S3_ENDPOINT_URL=https://oss-cn-hangzhou.aliyuncs.com
S3_REGION=cn-hangzhou
S3_BUCKET=jxccs-shared-infra-oss-cn-hangzhou
S3_ACCESS_KEY_ID=<oss-access-key-id>
S3_SECRET_ACCESS_KEY=<oss-access-key-secret>
S3_FORCE_PATH_STYLE=false
AWS_REQUEST_CHECKSUM_CALCULATION=when_required
AWS_RESPONSE_CHECKSUM_VALIDATION=when_required
UPLOAD_PREFIX=hr-certflow/local/certificates

DIFY_BASE_URL=https://<dify-internal-host>
DIFY_API_KEY=<dify-api-key>
DIFY_WORKFLOW_ID=certificate-extraction

WECOM_WEBHOOK_URL=
FEISHU_WEBHOOK_URL=
DINGTALK_WEBHOOK_URL=
NOTIFICATION_HR_RECIPIENTS=
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_STARTTLS=true
MAIL_FROM=
