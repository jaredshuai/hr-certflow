APP_NAME=HR CertFlow
APP_ENV=local
APP_TIMEZONE=Asia/Shanghai
AUTO_CREATE_TABLES=true
API_CORS_ORIGINS=http://localhost:8001

DATABASE_URL=postgresql+psycopg://<postgres-user>:<postgres-password>@<postgres-host>:5432/<postgres-db>
REDIS_URL=redis://<redis-user>:<redis-password>@<redis-host>:6379/0
CELERY_BROKER_URL=
CELERY_RESULT_BACKEND=
CELERY_NAMESPACE=hr-certflow-local
CELERY_QUEUE=hr-certflow-local
CELERY_ROUTING_KEY=hr-certflow-local
CELERY_REDIS_HASH_TAG=hr-certflow-local
CELERY_REDIS_PREFIX=hr-certflow-local:
POSTGRES_HOST_PORT=15432
REDIS_HOST_PORT=16379
S3_HOST_PORT=9000
S3_CONSOLE_HOST_PORT=9001
API_HOST_PORT=8000
FRONTEND_HOST_PORT=8001

S3_ENDPOINT_URL=http://object-storage:9000
S3_PUBLIC_ENDPOINT_URL=http://localhost:9000
S3_REGION=us-east-1
S3_BUCKET=hr-certflow
S3_ACCESS_KEY_ID=hr_certflow
S3_SECRET_ACCESS_KEY=hr_certflow_secret
S3_FORCE_PATH_STYLE=true

DIFY_BASE_URL=http://dify-api:5001
DIFY_API_KEY=replace-me
DIFY_WORKFLOW_ID=certificate-extraction

WECOM_WEBHOOK_URL=
FEISHU_WEBHOOK_URL=
DINGTALK_WEBHOOK_URL=
NOTIFICATION_HR_RECIPIENTS=
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_STARTTLS=true
MAIL_FROM=
